{
  "name": "knowem-party-game",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "vue-tsc --noEmit && vite build && tsc -p tsconfig.server.json",
    "preview": "vite preview",
    "start": "node dist-server/index.js"
  },
  "dependencies": {
    "@vueuse/motion": "^3.0.3",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "gsap": "^3.15.0",
    "lucide-vue-next": "^0.511.0",
    "pinia": "^3.0.3",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "vue": "^3.5.13",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/node": "^22.13.14",
    "@vitejs/plugin-vue": "^5.2.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "typescript": "~5.7.2",
    "vite": "^6.2.0",
    "vue-tsc": "^2.2.8"
  }
}
